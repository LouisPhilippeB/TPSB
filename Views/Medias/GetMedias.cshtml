@model IEnumerable<Models.Media>
@using DAL
@using Models

@if (Model.Count() != 0)
{
    foreach (var media in Model)
    {
        Models.User owner = DB.Users.Get(media.OwnerId);
        string avatar = owner != null ? owner.Avatar : "/App_Assets/Users/no_avatar.png";
        string ownerName = owner != null ? owner.Name : "";
        <div class="mediaLayout" style="position:relative;">
            <a href="/Medias/Details/@media.Id" title="Voir les détails de @media.Title" style="text-decoration:none; width:100% !important">
                <div class="mediaThumbnail"
                     style="background-image:url('https://img.youtube.com/vi/@media.YoutubeId/mqdefault.jpg'); position:relative;">
                    <img src="@avatar"
                         title="@ownerName"
                         style="position:absolute; top:6px; left:6px; width:32px; height:32px; border-radius:50%; object-fit:cover; border:2px solid white; box-shadow:0 0 4px rgba(0,0,0,0.5);" />
                </div>
            </a>

            <div class="ellipsis" style="margin-left:4px; margin-right:4px; font-size:0.8em; font-weight:bold">
                @media.Title
            </div>
            <div style="margin-left:4px; color:gray; font-size:0.65em">
                @media.Category
                @if (media.OwnerId == Models.User.ConnectedUser.Id)
                {
                    if (media.Shared)
                    {
                        <span> • Partagé</span>
                    }
                    else
                    {
                        <span> • Privé</span>
                    }
                }
                <br />
                @Helper.When(media.PublishDate)
            </div>
        </div>
    }
}
else
{
    <h3>Aucun résulat</h3>
}